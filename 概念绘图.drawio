  <diagram id="5aYU1n_cVGFT-JG1P1ZQ" name="文件操作缓冲区概念">
    <mxGraphModel dx="1216" dy="481" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="D-T9TuhwkltIq8kXk-_Z-1" value="Python程序所用内存" style="rounded=0;whiteSpace=wrap;html=1;fontSize=16;horizontal=1;labelPosition=center;verticalLabelPosition=bottom;align=center;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="-98" y="324" width="265" height="118" as="geometry" />
        </mxCell>
        <mxCell id="D-T9TuhwkltIq8kXk-_Z-3" value="硬盘" style="rounded=0;whiteSpace=wrap;html=1;fontSize=16;horizontal=1;labelPosition=center;verticalLabelPosition=bottom;align=center;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="283" y="324" width="265" height="118" as="geometry" />
        </mxCell>
        <mxCell id="D-T9TuhwkltIq8kXk-_Z-5" value="f.write(内容)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="-80" y="345" width="79" height="30" as="geometry" />
        </mxCell>
        <mxCell id="D-T9TuhwkltIq8kXk-_Z-13" value="f.flush()" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="D-T9TuhwkltIq8kXk-_Z-6" target="D-T9TuhwkltIq8kXk-_Z-12">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="D-T9TuhwkltIq8kXk-_Z-6" value="缓冲区" style="rounded=0;whiteSpace=wrap;html=1;labelPosition=center;verticalLabelPosition=bottom;align=center;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="37" y="330" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="D-T9TuhwkltIq8kXk-_Z-8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="D-T9TuhwkltIq8kXk-_Z-5">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="49" y="360" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="D-T9TuhwkltIq8kXk-_Z-11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="D-T9TuhwkltIq8kXk-_Z-9">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="120" y="378" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="D-T9TuhwkltIq8kXk-_Z-9" value="f.write(内容)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="-80" y="397" width="79" height="30" as="geometry" />
        </mxCell>
        <mxCell id="D-T9TuhwkltIq8kXk-_Z-12" value="文件" style="rounded=0;whiteSpace=wrap;html=1;labelPosition=center;verticalLabelPosition=bottom;align=center;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="314" y="345" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="D-T9TuhwkltIq8kXk-_Z-14" value="" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;" vertex="1" parent="1">
          <mxGeometry x="49" y="342" width="36" height="36" as="geometry" />
        </mxCell>
        <mxCell id="D-T9TuhwkltIq8kXk-_Z-15" value="" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;" vertex="1" parent="1">
          <mxGeometry x="102" y="342" width="36" height="36" as="geometry" />
        </mxCell>
        <mxCell id="D-T9TuhwkltIq8kXk-_Z-16" value="硬盘是低速设备，而程序是CPU执行，速度极快。&lt;div&gt;所以为了避免低速设备拉慢程序的执行，在操作的时候会在内存中开辟缓冲区，作用：&lt;/div&gt;&lt;div&gt;1. 将要写入硬盘的数据先积攒在缓冲区中&lt;/div&gt;&lt;div&gt;2. 当缓冲区满、或调用flush、或调用close的时候，数据才会从缓冲区真正写入硬盘&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;举例就相当于是要射出去10根箭&lt;/div&gt;&lt;div&gt;没有缓冲区就是，搭&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;箭、拉弓、射出，&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;搭&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;箭、拉弓、射出，...，&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;搭&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;箭、拉弓、射出， 10次&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;有缓冲区就是：&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;搭&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;箭&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;、&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;搭&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;箭、...、&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;搭&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;箭10次，拉弓、射出&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="-46" y="475" width="488" height="137" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
