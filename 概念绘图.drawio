        <mxCell id="oJbln69vNyZkM2B_7aAC-7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="oJbln69vNyZkM2B_7aAC-4" target="oJbln69vNyZkM2B_7aAC-2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="oJbln69vNyZkM2B_7aAC-4" value="lst = [1, 2, 3]" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="23" y="195.5" width="129" height="30" as="geometry" />
        </mxCell>
        <mxCell id="oJbln69vNyZkM2B_7aAC-6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="oJbln69vNyZkM2B_7aAC-5" target="oJbln69vNyZkM2B_7aAC-3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="oJbln69vNyZkM2B_7aAC-5" value="t1 = (1, 2, [1, 2, 3])" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="23" y="319.5" width="129" height="30" as="geometry" />
        </mxCell>
        <mxCell id="oJbln69vNyZkM2B_7aAC-8" value="[1, 2, 3]" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="409" y="321" width="89" height="27" as="geometry" />
        </mxCell>
        <mxCell id="oJbln69vNyZkM2B_7aAC-9" value="lst变量的内存是全部数据" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="354" y="197" width="178" height="30" as="geometry" />
        </mxCell>
        <mxCell id="oJbln69vNyZkM2B_7aAC-11" value="t1元组变量的数据存储是&lt;div&gt;1, 2, &lt;font style=&quot;color: light-dark(rgb(225, 20, 20), rgb(237, 237, 237));&quot;&gt;指针&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;即元组内并没有单独在内存中存放列表的全部数据&lt;/div&gt;&lt;div&gt;而是存了一个指针，&lt;/div&gt;&lt;div&gt;指向列表的内存区域&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="167" y="409" width="193" height="103" as="geometry" />
        </mxCell>
        <mxCell id="oJbln69vNyZkM2B_7aAC-13" value="[5, 6, 7]" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="378" y="260" width="120" height="18" as="geometry" />
        </mxCell>
        <mxCell id="oJbln69vNyZkM2B_7aAC-14" value="0x123466FE（内存地址）" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="402" y="344" width="155" height="30" as="geometry" />
        </mxCell>
        <mxCell id="oJbln69vNyZkM2B_7aAC-15" value="0x1234EEFF" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="408" y="271" width="60" height="30" as="geometry" />
        </mxCell>
        <mxCell id="oJbln69vNyZkM2B_7aAC-16" value="指针：就是一个内存的地址&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;内存地址就是内存的某个区域&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="459" y="431" width="238" height="81" as="geometry" />
        </mxCell>
        <mxCell id="oJbln69vNyZkM2B_7aAC-17" value="在元组中，对list的值进行修改新增等，不会影响指针的值，只是指针指向的内存区域的内容有变化而已&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;但是如果你要修改照这个指针为其它值，则不行&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="459" y="517" width="312" height="106" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
